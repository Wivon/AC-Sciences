{
  "name": "ac-sciences",
  "version": "1.2.0",
  "description": "Labo Claveille - Scientific Workbench",
  "main": "main.js",
  "scripts": {
    "start": "env -u ELECTRON_RUN_AS_NODE electron .",
    "prepare:ffmpeg-win": "node scripts/prepare-ffmpeg-win.js",
    "dist:win": "npm run prepare:ffmpeg-win && electron-builder --win portable --x64",
    "dist:mac": "electron-builder --mac dmg",
    "dist:linux": "electron-builder --linux AppImage deb --x64",
    "dist": "electron-builder --mac dmg --win portable --linux AppImage deb --x64"
  },
  "author": {
    "name": "Lilian Br",
    "email": "contact@vecting.org",
    "url": "https://labo-claveille.vecting.org"
  },
  "devDependencies": {
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "chart.js": "^4.4.0",
    "ffmpeg-static": "^5.3.0"
  },
  "build": {
    "appId": "fr.vecting.labo-claveille",
    "productName": "Labo Claveille",
    "asarUnpack": [
      "node_modules/ffmpeg-static/**"
    ],
    "extraResources": [
      {
        "from": "node_modules/ffmpeg-static",
        "to": "ffmpeg-static"
      }
    ],
    "fileAssociations": [
      {
        "ext": "lab",
        "name": "Labo Claveille Project",
        "description": "Labo Claveille Project",
        "role": "Editor"
      }
    ],
    "directories": {
      "buildResources": "build"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "build/logo.ico"
    },
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.developer-tools",
      "icon": "build/logo.icns"
    },
    "dmg": {
      "title": "Labo Claveille",
      "icon": "build/logo.icns",
      "contents": [
        { "x": 130, "y": 220, "type": "file" },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        },
        {
          "target": "deb",
          "arch": ["x64"]
        }
      ],
      "icon": "build/logo.png",
      "category": "Development",
      "mimeTypes": ["application/x-lab"]
    }
  }
}
